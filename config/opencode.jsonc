{
  "$schema": "https://opencode.ai/config.json",

  // ─── DEFAULT MODEL ─────────────────────────────────────
  // Change this to whatever model you want as your primary.
  "model": "opencode/big-pickle",

  // ─── AGENT MODEL ASSIGNMENTS ───────────────────────────
  // Free OpenCode models — no API key required.
  // Run `opencode models` to see all available models.
  //
  // Tier 1 (Strategic): opencode/big-pickle
  // Tier 2 (Balanced):  opencode/nemotron-3-super-free, opencode/minimax-m2.5-free
  // Tier 3 (Fast):      opencode/minimax-m2.5-free, opencode/qwen3.6-plus-free
  //
  // To switch to paid models: replace with anthropic/claude-sonnet-4-5, etc.
  // For Ollama local models: set LOCAL_ENDPOINT=http://localhost:11434/v1
  // Then use: local.qwen3:32b or local.{model-name}

  "agent": {
    "queen":      { "model": "opencode/big-pickle",             "temperature": 0.2 },
    "architect":  { "model": "opencode/big-pickle",             "temperature": 0.3 },
    "scripter":   { "model": "opencode/minimax-m2.5-free",      "temperature": 0.5 },
    "sentinel":   { "model": "opencode/nemotron-3-super-free",  "temperature": 0.1 },
    "documenter": { "model": "opencode/qwen3.6-plus-free",      "temperature": 0.7 },
    "refactor":   { "model": "opencode/minimax-m2.5-free",      "temperature": 0.4 }
  },

  // ─── PERMISSIONS ───────────────────────────────────────
  "permission": {
    "edit": "allow",
    "write": "allow",
    "bash": {
      "*": "ask",
      "npm test*": "allow",
      "npm run*": "allow",
      "npx*": "allow",
      "git*": "allow",
      "find*": "allow",
      "cat*": "allow",
      "ls*": "allow",
      "grep*": "allow"
    }
  },

  // ─── COMPACTION ────────────────────────────────────────
  "compaction": { "enabled": true },

  // ─── WATCHER ───────────────────────────────────────────
  "watcher": {
    "ignore": ["node_modules",".git",".arthur/sessions","dist","build",".next",".svelte-kit"]
  }
}
